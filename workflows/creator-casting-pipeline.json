      "parameters": {
        "jsCode": "// Build a show-specific scoring rubric. This is the core upgrade over\n// scoring everyone against one generic prompt - each show cares about\n// different things, and the AI prompt should reflect that.\nconst j = $json;\n\nconst rubrics = {\n  'Pop the Balloon': 'This is a fast-paced blind elimination dating show. Weight heavily: quick wit and comic timing, physical charisma that reads on camera, decisiveness under pressure, and grace in both rejecting and being rejected in front of an audience.',\n  'Find Your Match': 'This is a compatibility-focused matching show. Weight heavily: emotional intelligence, self-awareness, willingness to be genuinely vulnerable on camera, clarity about what they want in a partner, and any visible relationship red or green flags in their answers.',\n  'Who is the Liar': 'This is a social deception game show. Weight heavily: ability to bluff convincingly without breaking composure, sharp reasoning under pressure, comfort with confrontation, and how entertaining they are whether lying or catching someone else out.'\n};\n\nconst rubricPrompt = rubrics[j.episodeType]\n  || 'This is a general creator casting call. Weight heavily: on-camera charisma, authenticity, and overall entertainment value.';\n\nreturn { json: { ...j, rubricPrompt } };"
      },
      "id": "node-build-rubric",
      "name": "Build Show-Specific Rubric",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1740,
        400
      ]
    },
    {
      "parameters": {
        "model": "gpt-4o",
        "options": {
          "responseFormat": "json_object",
          "temperature": 0.3
        },
        "prompt": "=You are a casting producer's assistant. {{ $json.rubricPrompt }}\n\nReturn ONLY valid JSON in this exact shape:\n{\"charisma\": 1-10, \"authenticity\": 1-10, \"cameraPresence\": 1-10, \"dramaPotential\": 1-10, \"archetype\": \"short label\", \"redFlags\": \"none, or a brief description\", \"summary\": \"1-2 sentence producer note\"}\n\nEpisode type: {{ $json.episodeType }}\n\nApplicant questionnaire responses:\n{{ $json.questionnaire }}"
      },
      "id": "node-ai-scoring",
      "name": "AI Casting Score",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.4,
      "position": [
        1960,
        400
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "jsCode": "// Parse the AI response, fall back safely if it's malformed, and\n// compute a single weighted composite score + review bucket.\nconst upstream = $('Build Show-Specific Rubric').item.json;\nconst aiOutput = $input.item.json || {};\n\nlet parsed;\ntry {\n  const content = aiOutput.message?.content ?? aiOutput.content;\n  parsed = typeof content === 'string' ? JSON.parse(content) : content;\n} catch (e) {\n  parsed = null;\n}\nif (!parsed) {\n  parsed = {\n    charisma: 5, authenticity: 5, cameraPresence: 5, dramaPotential: 5,\n    archetype: 'Unclassified',\n    redFlags: 'AI scoring failed to parse - needs manual review',\n    summary: 'Automated scoring failed for this applicant. Please review manually.'\n  };\n}\n\nconst weights = { charisma: 0.30, authenticity: 0.25, cameraPresence: 0.25, dramaPotential: 0.20 };\nconst composite = Object.keys(weights).reduce(\n  (sum, k) => sum + (Number(parsed[k]) || 5) * weights[k], 0\n);\nconst compositeScore = Math.round(composite * 10) / 10;\n\nlet bucket = 'Pass';\nif (compositeScore >= 8.5) bucket = 'Strong Shortlist';\nelse if (compositeScore >= 6) bucket = 'Maybe';\n\n// A red flag should always get a human look, no matter how high the\n// score is. Never let this auto-promote someone straight to an instant\n// producer alert.\nconst hasRedFlag = parsed.redFlags && String(parsed.redFlags).trim().toLowerCase() !== 'none' && String(parsed.redFlags).trim() !== '';\nif (hasRedFlag && bucket === 'Strong Shortlist') bucket = 'Maybe';\n\nreturn {\n  json: {\n    ...upstream,\n    charisma: parsed.charisma,\n    authenticity: parsed.authenticity,\n    cameraPresence: parsed.cameraPresence,\n    dramaPotential: parsed.dramaPotential,\n    archetype: parsed.archetype,\n    redFlags: parsed.redFlags,\n    producerSummary: parsed.summary,\n    compositeScore,\n    bucket\n  }\n};"
      },
      "id": "node-parse-score",
      "name": "Parse Score & Compute Bucket",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2180,
        400
      ]
