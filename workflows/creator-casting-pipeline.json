      "parameters": {
        "jsCode": "// Hard eligibility gate. Anything that fails here never reaches the\n// AI scoring step - saves API spend and avoids sending a \"fix your\n// video link\" email to someone who was never eligible in the first place.\n//\n// EDIT THIS LIST to match the cities/regions you can actually film in.\nconst VALID_LOCATIONS = ['Lagos', 'Abuja', 'Port Harcourt', 'Ibadan', 'Kano', 'Benin City', 'Kaduna'];\n\nconst j = $json;\nconst reasons = [];\n\nif (!j.isValidEmail) reasons.push('Invalid email format');\nif (!j.fileId) reasons.push('No valid Google Drive link provided');\nif (j.age === null) reasons.push('Date of birth missing or unreadable');\nelse if (!j.isAdult) reasons.push('Under 18');\nif (!j.availabilityConfirmed) reasons.push('Not available for filming dates');\nif (!j.location || !VALID_LOCATIONS.includes(j.location)) reasons.push(`Location (${j.location || 'not provided'}) is outside filming range`);\n\nreturn {\n  json: {\n    ...j,\n    meetsBasicCriteria: reasons.length === 0,\n    disqualifyReasons: reasons.join('; ')\n  }\n};"
      },
