    {
      "parameters": {
        "jsCode": "// Real duplicate-identity check: compares this applicant's phone,\n// Instagram, and TikTok against every row already in Master_Log. A\n// fingerprint that's never looked up against past records isn't\n// deduplication - this is the lookup that makes it actually mean something.\n// Soft flag only, not an auto-reject: shared devices/handles happen\n// (e.g. siblings), so a producer should still make the call.\nconst applicant = $('Sanitize & Normalize Payload').item.json;\nconst existingRows = $input.all().map(i => i.json);\n\nconst matches = existingRows.filter(row => {\n  if ((row['Email'] || '').toLowerCase() === applicant.email) return false; // same person reapplying, not a dupe\n  const samePhone = applicant.whatsappDigits && row['Phone Digits'] === applicant.whatsappDigits;\n  const sameIG = applicant.instagramNormalized && row['IG Handle'] === applicant.instagramNormalized;\n  const sameTT = applicant.tiktokNormalized && row['TikTok Handle'] === applicant.tiktokNormalized;\n  return samePhone || sameIG || sameTT;\n});\n\nreturn {\n  json: {\n    ...applicant,\n    isDuplicateIdentity: matches.length > 0,\n    duplicateMatchEmails: matches.map(m => m['Email']).join(', ')\n  }\n};"
      },
      "id": "node-dup-flag",
      "name": "Flag Duplicate Identity",
      "type": "n8n-nodes-base.code",
