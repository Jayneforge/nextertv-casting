    {
      "parameters": {
        "jsCode": "// Normalize + sanitize the raw form payload.\n// Assumes the webform sends: fullName, email, whatsapp, instagram, tiktok,\n// episodeType, googleDriveLink, dateOfBirth, location, availabilityConfirmed,\n// and questionnaireAnswers (JSON string or array of { question, answer }\n// pairs - lets the per-show dynamic question set on the frontend stay\n// decoupled from this node).\n\nconst b = $input.item.json.body || $input.item.json || {};\nconst clean = (s) => (s !== undefined && s !== null ? String(s).trim() : '');\nconst cleanHandle = (h) => {\n  if (!h) return '';\n  const x = String(h).trim();\n  return x.startsWith('@') ? x : '@' + x;\n};\nconst toBool = (v) => v === true || v === 'true' || v === 'on' || v === '1';\n\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\nconst email = clean(b.email).toLowerCase();\nconst isValidEmail = emailRegex.test(email);\n\nconst driveUrl = clean(b.googleDriveLink);\nconst match = driveUrl.match(/\\/d\\/([a-zA-Z0-9_-]+)/) || driveUrl.match(/id=([a-zA-Z0-9_-]+)/);\n\nlet qaPairs = [];\ntry {\n  qaPairs = typeof b.questionnaireAnswers === 'string'\n    ? JSON.parse(b.questionnaireAnswers)\n    : (Array.isArray(b.questionnaireAnswers) ? b.questionnaireAnswers : []);\n} catch (e) {\n  qaPairs = [];\n}\nconst questionnaireText = qaPairs\n  .map(qa => `Q: ${clean(qa.question)}\\nA: ${clean(qa.answer)}`)\n  .join('\\n\\n');\n\nconst episodeType = clean(b.episodeType) || 'Other Formats';\n\n// Age from actual date of birth, not a self-reported checkbox.\nconst dobRaw = clean(b.dateOfBirth);\nconst dob = dobRaw ? new Date(dobRaw) : null;\nconst dobValid = dob instanceof Date && !isNaN(dob.getTime());\nconst age = dobValid ? Math.floor((Date.now() - dob.getTime()) / (365.25 * 24 * 60 * 60 * 1000)) : null;\nconst isAdult = dobValid && age >= 18;\n\nconst location = clean(b.location);\nconst whatsappDigits = clean(b.whatsapp).replace(/\\D/g, '');\nconst instagramNormalized = cleanHandle(b.instagram).toLowerCase().replace('@', '');\nconst tiktokNormalized = cleanHandle(b.tiktok).toLowerCase().replace('@', '');\n\nreturn {\n  json: {\n    fullName: clean(b.fullName),\n    email,\n    isValidEmail,\n    whatsapp: clean(b.whatsapp),\n    whatsappDigits,\n    instagram: cleanHandle(b.instagram),\n    instagramNormalized,\n    tiktok: cleanHandle(b.tiktok),\n    tiktokNormalized,\n    episodeType,\n    googleDriveLink: driveUrl,\n    fileId: match ? match[1] : null,\n    questionnaire: questionnaireText,\n    dateOfBirth: dobRaw,\n    age,\n    isAdult,\n    location,\n    availabilityConfirmed: toBool(b.availabilityConfirmed),\n    applicationKey: `${email}::${episodeType}`,\n    submissionTimestamp: new Date().toISOString()\n  }\n};"
      },
